---
import '../styles/app.css';
import { getThemeAttributes } from '../lib/appearance';

const themeAttrs = getThemeAttributes();
---

<html lang="en" {...themeAttrs}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Astro Theme Lotus</title>
  </head>
  <body class="min-h-screen bg-[var(--lotus-bg)] text-[var(--lotus-fg)]">
    <main class="mx-auto max-w-3xl px-6 py-16">
      <p class="text-sm font-medium text-[var(--lotus-accent)]">Astro Theme Lotus</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">Documentation starts in /docs/</h1>
      <p class="mt-4 text-[var(--lotus-muted)]">
        The primary experience for this project is the documentation site.
      </p>
      <p class="mt-8">
        <a
          class="inline-flex items-center rounded-full border border-[var(--lotus-border)] px-5 py-3 text-sm font-medium text-[var(--lotus-fg)] transition-colors hover:border-[var(--lotus-accent)] hover:text-[var(--lotus-accent)]"
          href="/docs/"
        >
          Open the docs
        </a>
      </p>
    </main>
  </body>
</html>
