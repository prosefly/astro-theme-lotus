---
import '../styles/app.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Astro Theme Lotus</title>
  </head>
  <body class="min-h-screen bg-white text-zinc-950">
    <main class="mx-auto max-w-3xl px-6 py-16">
      <p class="text-sm font-medium text-indigo-600">Astro Theme Lotus</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">
        Documentation theme foundation
      </h1>
      <p class="mt-4 text-zinc-600">
        Astro v7, Tailwind CSS v4, and MDX are ready for the documentation
        theme.
      </p>
    </main>
  </body>
</html>
