---
import { Icon } from '@prosefly/astro-components';
import { PageSection } from '@prosefly/astro-theme-lotus/layouts';

const packages = [
  {
    name: '@prosefly/astro-theme-lotus',
    role: 'Docs integration, routes, navigation, search, and design tokens',
  },
  {
    name: '@prosefly/astro-components',
    role: 'Callouts, tabs, steps, cards, file trees, icons, and other MDX UI',
  },
];

const included = [
  'Astro integration and generated docs routes',
  'Responsive header, subnav, sidebar, and table of contents',
  'Local search data and Markdown source routes',
  'Dark mode and configurable appearance tokens',
  'Reusable Markdown and MDX components',
  'Locale-aware documentation trees',
  'Commercial use under BSD-3-Clause',
  'Deployment to the static host you choose',
];
---

<PageSection class="border-b border-(--lotus-border-subtle) bg-(--lotus-surface)/55" padding="lg" size="xl">
  <div class="grid gap-12 lg:grid-cols-[minmax(0,0.75fr)_minmax(28rem,1.25fr)]">
    <div>
      <p class="section-label">Repository manifest</p>
      <h2 class="heading mt-3">Two packages. One open feature set.</h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-(--lotus-text-muted)">
        The theme and its MDX component library are developed together. The
        price does not change based on project count, team size, or traffic.
      </p>
    </div>

    <div class="manifest border-y border-(--lotus-border-subtle)">
      {packages.map((pkg, index) => (
        <article>
          <span class="manifest-index">0{index + 1}</span>
          <div class="min-w-0">
            <h3><code>{pkg.name}</code></h3>
            <p>{pkg.role}</p>
          </div>
          <Icon name="lucide:package" />
        </article>
      ))}
    </div>
  </div>

  <div class="included-grid mt-14 grid sm:grid-cols-2 lg:grid-cols-4">
    {included.map((item) => (
      <div>
        <Icon name="lucide:check" />
        <span>{item}</span>
      </div>
    ))}
  </div>
</PageSection>

<style>
  .section-label {
    color: var(--lotus-text-muted);
    font-family: var(--lotus-font-mono);
    font-size: 0.8125rem;
  }

  .heading {
    color: var(--lotus-text-strong);
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.02;
  }

  .manifest article {
    align-items: center;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 2rem minmax(0, 1fr) auto;
    padding-block: 1.4rem;
  }

  .manifest article + article {
    border-top: 1px solid var(--lotus-border-subtle);
  }

  .manifest-index {
    color: var(--lotus-text-subtle);
    font-family: var(--lotus-font-mono);
    font-size: 0.6875rem;
  }

  .manifest h3 {
    color: var(--lotus-text-strong);
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0;
    overflow-wrap: anywhere;
  }

  .manifest p {
    color: var(--lotus-text-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
    margin: 0.35rem 0 0;
  }

  .manifest :global(.pl-icon) {
    color: var(--lotus-accent);
    height: 1.1rem;
    width: 1.1rem;
  }

  .included-grid {
    border-left: 1px solid var(--lotus-border-subtle);
    border-top: 1px solid var(--lotus-border-subtle);
  }

  .included-grid > div {
    align-items: flex-start;
    border-bottom: 1px solid var(--lotus-border-subtle);
    border-right: 1px solid var(--lotus-border-subtle);
    color: var(--lotus-text);
    display: flex;
    font-size: 0.8125rem;
    gap: 0.7rem;
    line-height: 1.55;
    min-height: 6.75rem;
    padding: 1.25rem;
  }

  .included-grid :global(.pl-icon) {
    color: var(--lotus-accent);
    flex: 0 0 auto;
    height: 1rem;
    margin-top: 0.12rem;
    width: 1rem;
  }

  @media (max-width: 639px) {
    .included-grid > div {
      min-height: 0;
    }
  }
</style>
