---
import { Card, CardGrid, Icon } from '@prosefly/astro-components';

const subnavItems = [
  { icon: 'lucide:rocket', label: 'Guides', active: true },
  { icon: 'lucide:blocks', label: 'Components' },
  { icon: 'lucide:chef-hat', label: 'Recipes' },
  { icon: 'lucide:book-open', label: 'References' },
];

const sidebarItems = ['Overview', 'Installation', 'Configuration', 'Deployment'];
---

<figure class="docs-preview overflow-hidden border border-(--lotus-border-subtle) bg-(--lotus-background) shadow-2xl shadow-black/10">
  <div class="docs-preview__canvas" aria-hidden="true">
    <div class="docs-preview__header">
      <span class="docs-preview__brand">
        <img src="/favicon.svg" alt="" width="32" height="32" />
        <strong>Lotus</strong>
      </span>
      <span class="docs-preview__search">
        <Icon name="lucide:search" />
        Search docs
      </span>
      <span class="docs-preview__actions">
        <span>Docs</span>
        <span class="docs-preview__source">Source <Icon name="lucide:chevron-right" /></span>
        <Icon name="lucide:palette" />
        <Icon name="lucide:moon-star" />
      </span>
    </div>

    <div class="docs-preview__subnav">
      {subnavItems.map((item) => (
        <span class:list={['docs-preview__subnav-item', { active: item.active }]}>
          <Icon name={item.icon} />
          {item.label}
        </span>
      ))}
    </div>

    <div class="docs-preview__body">
      <aside class="docs-preview__sidebar">
        <span class="docs-preview__blog"><Icon name="lucide:newspaper" /> Blog</span>
        <strong>Getting Started</strong>
        {sidebarItems.map((item, index) => (
          <span class:list={['docs-preview__sidebar-item', { active: index === 0 }]}>
            {item}
            {item === 'Configuration' && <Icon name="lucide:chevron-right" />}
          </span>
        ))}
        <span class="docs-preview__rule"></span>
        <strong>Essentials</strong>
        <span class="docs-preview__sidebar-item">Frontmatter</span>
        <span class="docs-preview__sidebar-item">Markdown Syntax</span>
      </aside>

      <article class="docs-preview__article">
        <div class="docs-preview__article-topline">
          <span>Getting Started</span>
          <span class="docs-preview__copy"><Icon name="lucide:copy" /> Copy page</span>
        </div>
        <h2>Overview</h2>
        <p class="docs-preview__lede">Learn what Lotus provides and how the documentation theme is organized.</p>
        <span class="docs-preview__rule"></span>
        <p>
          Lotus provides the page shell, navigation model, theme tokens, and
          shared MDX components needed to start documentation without rebuilding
          the chrome from scratch.
        </p>
        <h3>What Lotus includes</h3>
        <div class="docs-preview__cards">
          <CardGrid>
            <Card icon="lucide:layout-template" title="Docs shell">
              Responsive navigation and search.
            </Card>
            <Card icon="lucide:route" title="Routing">
              Content-driven Astro pages.
            </Card>
          </CardGrid>
        </div>
      </article>

      <aside class="docs-preview__toc">
        <strong>On this page</strong>
        <span>What Lotus includes</span>
        <span>How the docs tree works</span>
        <span>First steps</span>
        <span class="docs-preview__rule"></span>
        <span><Icon name="lucide:pencil" /> Edit this page</span>
      </aside>
    </div>
  </div>

  <figcaption>
    <span><i></i>Live token preview</span>
    <a class="lotus-focus-ring" href="/docs/overview/">
      View live docs <Icon name="lucide:arrow-up-right" />
    </a>
  </figcaption>
</figure>

<style>
  .docs-preview {
    border-radius: min(var(--lotus-radius-lg), 1.25rem);
    container-type: inline-size;
    min-width: 0;
    transform: perspective(1200px) rotateY(-2deg) rotateX(1deg);
  }

  .docs-preview__canvas {
    color: var(--lotus-text);
    font-size: 0.625rem;
    line-height: 1.45;
  }

  .docs-preview__header,
  .docs-preview__subnav {
    align-items: center;
    border-bottom: 1px solid var(--lotus-border-subtle);
    display: flex;
  }

  .docs-preview__header {
    gap: 1rem;
    height: 3.25rem;
    padding: 0 1rem;
  }

  .docs-preview__brand,
  .docs-preview__search,
  .docs-preview__actions,
  .docs-preview__subnav-item,
  .docs-preview__blog,
  .docs-preview__article-topline,
  .docs-preview__copy,
  .docs-preview__toc span,
  figcaption,
  figcaption span,
  figcaption a {
    align-items: center;
    display: flex;
  }

  .docs-preview__brand {
    color: var(--lotus-text-strong);
    flex: 0 0 auto;
    font-size: 0.75rem;
    gap: 0.4rem;
  }

  .docs-preview__brand img {
    height: 1.35rem;
    width: 1.35rem;
  }

  .docs-preview__search {
    border: 1px solid var(--lotus-border-muted);
    border-radius: var(--lotus-radius-md);
    color: var(--lotus-text-muted);
    flex: 0 1 8.5rem;
    gap: 0.45rem;
    height: 1.8rem;
    padding: 0 0.65rem;
  }

  .docs-preview__actions {
    color: var(--lotus-text-muted);
    gap: 0.7rem;
    margin-left: auto;
  }

  .docs-preview__source {
    align-items: center;
    background: var(--lotus-text-strong);
    border-radius: var(--lotus-radius-md);
    color: var(--lotus-background);
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.38rem 0.55rem;
  }

  .docs-preview__subnav {
    gap: 1.15rem;
    height: 2.65rem;
    padding: 0 1rem;
  }

  .docs-preview__subnav-item {
    align-self: stretch;
    color: var(--lotus-text-muted);
    gap: 0.35rem;
    position: relative;
  }

  .docs-preview__subnav-item.active {
    color: var(--lotus-accent);
  }

  .docs-preview__subnav-item.active::after {
    background: var(--lotus-accent);
    bottom: -1px;
    content: '';
    height: 2px;
    inset-inline: 0;
    position: absolute;
  }

  .docs-preview__body {
    display: grid;
    grid-template-columns: 8.6rem minmax(0, 1fr) 7.2rem;
    min-height: 20.5rem;
  }

  .docs-preview__sidebar {
    border-right: 1px solid var(--lotus-border-subtle);
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    padding: 1rem 0.75rem;
  }

  .docs-preview__sidebar strong {
    color: var(--lotus-text-strong);
    font-size: 0.5625rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0.65rem 0 0.28rem;
  }

  .docs-preview__toc strong {
    color: var(--lotus-text-strong);
    font-size: 0.625rem;
    font-weight: 600;
    margin: 0.75rem 0 0.35rem;
  }

  .docs-preview__blog {
    color: var(--lotus-text-muted);
    gap: 0.35rem;
    margin-bottom: 0.45rem;
  }

  .docs-preview__sidebar-item {
    align-items: center;
    border-radius: var(--lotus-radius-md);
    color: var(--lotus-text-muted);
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0.5rem;
  }

  .docs-preview__sidebar-item.active {
    background: var(--lotus-accent-soft);
    color: var(--lotus-accent);
    font-weight: 600;
  }

  .docs-preview__rule {
    background: var(--lotus-border-subtle);
    display: block;
    height: 1px;
    margin: 0.65rem 0;
    width: 100%;
  }

  .docs-preview__article {
    min-width: 0;
    padding: 1.2rem 1.35rem;
  }

  .docs-preview__article-topline {
    color: var(--lotus-accent);
    justify-content: space-between;
  }

  .docs-preview__copy {
    border: 1px solid var(--lotus-border-muted);
    border-radius: var(--lotus-radius-md);
    color: var(--lotus-text-strong);
    gap: 0.3rem;
    padding: 0.3rem 0.45rem;
  }

  .docs-preview__article h2 {
    color: var(--lotus-text-strong);
    font-size: 1.4rem;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin: 0.6rem 0;
  }

  .docs-preview__article h3 {
    color: var(--lotus-text-strong);
    font-size: 0.9rem;
    margin: 1.15rem 0 0.65rem;
  }

  .docs-preview__article p {
    line-height: 1.7;
    margin: 0;
  }

  .docs-preview__lede {
    color: var(--lotus-text-muted);
    font-size: 0.7rem;
  }

  .docs-preview__cards {
    --pl-card-body-gap: 0.15rem;
    --pl-card-content-line-height: 1.4;
    --pl-card-content-size: 0.55rem;
    --pl-card-icon-glyph-size: 0.75rem;
    --pl-card-icon-size: 1.45rem;
    --pl-card-layout-gap: 0.35rem;
    --pl-card-padding: 0.65rem;
    --pl-card-title-line-height: 0.85rem;
    --pl-card-title-size: 0.625rem;
  }

  .docs-preview__cards :global(.pl-card-grid) {
    gap: 0.65rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-block: 0;
  }

  .docs-preview__cards :global(.pl-card) {
    min-width: 0;
  }

  .docs-preview__toc {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1rem 0.8rem;
  }

  .docs-preview__toc strong {
    margin-top: 0;
  }

  .docs-preview__toc span {
    color: var(--lotus-text-muted);
    gap: 0.3rem;
  }

  figcaption {
    border-top: 1px solid var(--lotus-border-subtle);
    color: var(--lotus-text-muted);
    font-size: 0.75rem;
    justify-content: space-between;
    padding: 0.75rem 1rem;
  }

  figcaption span,
  figcaption a {
    gap: 0.4rem;
  }

  figcaption i {
    background: var(--lotus-accent);
    border-radius: 999px;
    height: 0.4rem;
    width: 0.4rem;
  }

  figcaption a {
    border-radius: var(--lotus-radius-sm);
    color: var(--lotus-accent);
    font-weight: 600;
  }

  .docs-preview :global(.pl-icon) {
    height: 0.8rem;
    width: 0.8rem;
  }

  @container (max-width: 31rem) {
    .docs-preview__body {
      grid-template-columns: 7.3rem minmax(0, 1fr);
    }

    .docs-preview__toc {
      display: none;
    }

    .docs-preview__actions > :nth-child(n + 3),
    .docs-preview__subnav-item:nth-child(n + 4) {
      display: none;
    }
  }

  @container (max-width: 23rem) {
    .docs-preview__header {
      gap: 0.5rem;
      padding-inline: 0.7rem;
    }

    .docs-preview__search {
      flex-basis: 6.5rem;
    }

    .docs-preview__actions {
      display: none;
    }

    .docs-preview__subnav-item:nth-child(n + 3) {
      display: none;
    }

    .docs-preview__body {
      grid-template-columns: 6.4rem minmax(0, 1fr);
    }

    .docs-preview__article {
      padding-inline: 0.8rem;
    }

    .docs-preview__cards :global(.pl-card-grid) {
      grid-template-columns: 1fr;
    }

    .docs-preview__cards :global(.pl-card:last-child) {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .docs-preview {
      transform: none;
    }
  }
</style>
