---
import { Icon } from '@prosefly/astro-components';
import { PageSection } from '@prosefly/astro-theme-lotus/layouts';

const reports = [
  {
    title: 'PageSpeed Insights',
    description: 'Current mobile report scores 100 across all categories.',
    href: 'https://pagespeed.web.dev/analysis/https-astro-theme-lotus-prosefly-dev-docs-installation/e31wz7q0ic?form_factor=mobile',
    icon: 'lucide:gauge',
    eyebrow: 'Mobile report',
    metric: '100 / 100',
  },
  {
    title: 'Website Carbon',
    description: 'External estimate for the installation page.',
    href: 'https://www.websitecarbon.com/website/astro-theme-lotus-prosefly-dev-docs-installation/',
    icon: 'lucide:leaf',
    eyebrow: 'External estimate',
    metric: 'Low impact',
  },
];

const traits = ['Static output', 'Minimal client JavaScript', 'Deploy-friendly search'];
---

<PageSection class="home-proof bg-(--lotus-background)" padding="lg" size="xl">
  <div class="proof-panel grid gap-10 lg:grid-cols-[minmax(0,0.75fr)_minmax(30rem,1fr)] lg:items-center">
    <div>
      <p class="section-label">Built for static docs</p>
      <h2 class="heading mt-3">Fast, lightweight documentation by default.</h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-(--lotus-text-muted)">
        Lotus keeps the docs shell static-first, with focused client JavaScript
        for navigation, search, and theme controls. External reports stay one
        click away without turning the homepage into a score dashboard.
      </p>
      <ul class="trait-list mt-7">
        {traits.map((trait) => (
          <li><Icon name="lucide:check" /> {trait}</li>
        ))}
      </ul>
    </div>

    <div class="proof-grid grid gap-4 sm:grid-cols-2">
      {reports.map((report) => (
        <a class="proof-card lotus-focus-ring" href={report.href} target="_blank" rel="noreferrer">
          <span class="proof-card__topline">
            <span class="proof-card__icon"><Icon name={report.icon} /></span>
            <span class="proof-card__eyebrow">{report.eyebrow}</span>
          </span>
          <span class="proof-card__metric">{report.metric}</span>
          <span class="proof-card__body">
            <strong>{report.title}</strong>
            <span>{report.description}</span>
          </span>
          <span class="proof-card__link">Open report <Icon name="lucide:arrow-up-right" /></span>
        </a>
      ))}
    </div>
  </div>
</PageSection>

<style>
  .section-label {
    color: var(--lotus-text-muted);
    font-family: var(--lotus-font-mono);
    font-size: 0.8125rem;
  }

  .heading {
    color: var(--lotus-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .proof-panel {
    background: color-mix(in oklab, var(--lotus-surface) 52%, var(--lotus-background));
    border: 1px solid var(--lotus-border-subtle);
    border-radius: min(var(--lotus-radius-2xl), 1.5rem);
    padding: clamp(1.25rem, 4vw, 2.5rem);
  }

  .trait-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin-bottom: 0;
    padding: 0;
  }

  .trait-list li {
    align-items: center;
    border: 1px solid var(--lotus-border-subtle);
    border-radius: var(--lotus-radius-md);
    color: var(--lotus-text);
    display: inline-flex;
    font-size: 0.8125rem;
    gap: 0.45rem;
    padding: 0.45rem 0.65rem;
  }

  .trait-list :global(.pl-icon),
  .proof-card :global(.pl-icon) {
    height: 1rem;
    width: 1rem;
  }

  .trait-list :global(.pl-icon) {
    color: var(--lotus-accent);
  }

  .proof-card {
    background: color-mix(in oklab, var(--lotus-background) 88%, transparent);
    border: 1px solid var(--lotus-border-subtle);
    border-radius: min(var(--lotus-radius-lg), 0.9rem);
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .proof-card:hover {
    border-color: var(--lotus-accent);
    box-shadow: 0 18px 40px color-mix(in oklab, var(--lotus-accent) 12%, transparent);
    transform: translateY(-2px);
  }

  .proof-card__icon {
    align-items: center;
    background: color-mix(in oklab, #22c55e 14%, transparent);
    border-radius: var(--lotus-radius-md);
    color: #16a34a;
    display: inline-flex;
    height: 2.25rem;
    justify-content: center;
    width: 2.25rem;
  }

  .proof-card__topline {
    align-items: center;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .proof-card__eyebrow {
    color: var(--lotus-text-subtle);
    font-family: var(--lotus-font-mono);
    font-size: 0.6875rem;
  }

  .proof-card__metric {
    color: var(--lotus-text-strong);
    font-size: clamp(1.8rem, 4vw, 2.65rem);
    font-weight: 650;
    letter-spacing: -0.045em;
    line-height: 0.95;
  }

  .proof-card__body {
    display: grid;
    gap: 0.55rem;
  }

  .proof-card__body strong {
    color: var(--lotus-text-strong);
    font-size: 1rem;
  }

  .proof-card__body span {
    color: var(--lotus-text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .proof-card__link {
    align-items: center;
    color: var(--lotus-accent);
    display: inline-flex;
    font-size: 0.875rem;
    font-weight: 600;
    gap: 0.45rem;
    margin-top: auto;
  }
</style>
