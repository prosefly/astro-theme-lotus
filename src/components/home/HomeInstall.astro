---
import { Icon } from '@prosefly/astro-components';
import { CodeBlock } from '@prosefly/astro-theme-lotus/components';
import { PageSection } from '@prosefly/astro-theme-lotus/layouts';

const astroConfigCode = `
import { defineConfig } from 'astro/config';
import lotus from '@prosefly/astro-theme-lotus';
import themeConfig from './src/theme.config';

export default defineConfig({
  integrations: [lotus(themeConfig)],
});
`;
---

<PageSection class="border-t border-(--lotus-border-subtle) bg-(--lotus-surface)/55" padding="lg" size="xl">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,0.7fr)_minmax(30rem,1fr)] lg:items-center">
    <div>
      <p class="section-label">Installation</p>
      <h2 class="heading mt-3">Add Lotus to an existing Astro project.</h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-(--lotus-text-muted)">
        Install the theme package, pass the theme config directly to the
        integration, and register the docs content collection.
      </p>
      <a class="text-link lotus-focus-ring mt-7" href="/docs/installation/">
        Read the installation guide <Icon name="lucide:arrow-right" />
      </a>
    </div>

    <CodeBlock class="install-code" code={astroConfigCode} lang="ts" title="astro.config.ts" />
  </div>

  <dl class="setup-facts mt-12 grid border-y border-(--lotus-border-subtle) md:grid-cols-3">
    <div>
      <dt>Packages</dt>
      <dd><code>@prosefly/astro-theme-lotus</code> + <code>@prosefly/astro-components</code></dd>
    </div>
    <div>
      <dt>Content collection</dt>
      <dd><code>docsLoader()</code> + <code>docsSchema()</code></dd>
    </div>
    <div>
      <dt>Docs route</dt>
      <dd><code>/docs</code> on this site</dd>
    </div>
  </dl>

  <div class="mt-10 flex flex-wrap items-center justify-between gap-4">
    <p class="text-sm text-(--lotus-text-muted)">The homepage remains a normal Astro route.</p>
    <div class="flex flex-wrap gap-5">
      <a class="text-link lotus-focus-ring" href="/docs/overview/">
        Open the docs <Icon name="lucide:arrow-up-right" />
      </a>
      <a class="text-link lotus-focus-ring" href="https://github.com/prosefly/astro-theme-lotus">
        View source <Icon name="simple-icons:github" />
      </a>
    </div>
  </div>
</PageSection>

<style>
  .section-label {
    color: var(--lotus-text-muted);
    font-family: var(--lotus-font-mono);
    font-size: 0.8125rem;
  }

  .heading {
    color: var(--lotus-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  :global(.install-code) :global(.lotus-code-block__header) {
    align-items: center;
    background: var(--lotus-surface);
    display: flex;
    gap: 0.375rem;
    justify-content: space-between;
  }

  :global(.install-code) :global(.lotus-code-block__header)::after {
    color: var(--lotus-text-subtle);
    content: 'Ready';
    font-family: var(--lotus-font-sans);
    font-size: 0.75rem;
    font-weight: 400;
  }

  :global(.install-code) :global(.lotus-code-block__header)::before {
    background: oklch(0.69 0.17 149);
    border-radius: 999px;
    content: '';
    height: 0.375rem;
    margin-left: auto;
    order: 1;
    width: 0.375rem;
  }

  :global(.install-code) :global(.lotus-code-block__header)::after {
    order: 2;
  }

  :global(.install-code) :global(.shiki) {
    padding: 1.25rem;
  }

  .text-link {
    align-items: center;
    border-radius: var(--lotus-radius-sm);
    color: var(--lotus-accent);
    display: inline-flex;
    font-size: 0.875rem;
    font-weight: 600;
    gap: 0.5rem;
  }

  .text-link :global(.pf-icon) {
    height: 1rem;
    width: 1rem;
  }

  .setup-facts > div {
    padding: 1.25rem 1.5rem;
  }

  .setup-facts > div + div {
    border-left: 1px solid var(--lotus-border-subtle);
  }

  .setup-facts dt {
    color: var(--lotus-text-subtle);
    font-size: 0.75rem;
    margin-bottom: 0.45rem;
  }

  .setup-facts dd {
    color: var(--lotus-text);
    font-size: 0.8125rem;
    margin: 0;
    overflow-wrap: anywhere;
  }

  .setup-facts code {
    color: var(--lotus-text-strong);
    font-family: var(--lotus-font-mono);
    font-size: 0.75rem;
  }

  @media (max-width: 767px) {
    .setup-facts > div {
      padding-inline: 0.25rem;
    }

    .setup-facts > div + div {
      border-left: 0;
      border-top: 1px solid var(--lotus-border-subtle);
    }
  }
</style>
