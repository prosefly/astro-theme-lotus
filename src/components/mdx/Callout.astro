---
interface Props {
  title?: string;
  type?: 'note' | 'tip' | 'warning' | 'danger';
}

const { title, type = 'note' } = Astro.props;

const variants = {
  note: {
    label: 'Note',
    wrapper:
      'border-[color:color-mix(in_oklab,var(--lotus-accent)_24%,var(--lotus-border))] bg-[color:color-mix(in_oklab,var(--lotus-accent)_8%,var(--lotus-bg))]',
    rail: 'bg-[var(--lotus-accent)]',
    eyebrow: 'text-[var(--lotus-accent)]',
  },
  tip: {
    label: 'Tip',
    wrapper:
      'border-[color:color-mix(in_oklab,oklch(0.64_0.16_155)_32%,var(--lotus-border))] bg-[color:color-mix(in_oklab,oklch(0.64_0.16_155)_10%,var(--lotus-bg))]',
    rail: 'bg-[color:oklch(0.64_0.16_155)]',
    eyebrow: 'text-[color:oklch(0.45_0.13_155)] dark:text-[color:oklch(0.77_0.12_155)]',
  },
  warning: {
    label: 'Warning',
    wrapper:
      'border-[color:color-mix(in_oklab,oklch(0.74_0.16_80)_36%,var(--lotus-border))] bg-[color:color-mix(in_oklab,oklch(0.74_0.16_80)_12%,var(--lotus-bg))]',
    rail: 'bg-[color:oklch(0.74_0.16_80)]',
    eyebrow: 'text-[color:oklch(0.5_0.12_80)] dark:text-[color:oklch(0.82_0.12_80)]',
  },
  danger: {
    label: 'Danger',
    wrapper:
      'border-[color:color-mix(in_oklab,oklch(0.62_0.2_25)_34%,var(--lotus-border))] bg-[color:color-mix(in_oklab,oklch(0.62_0.2_25)_10%,var(--lotus-bg))]',
    rail: 'bg-[color:oklch(0.62_0.2_25)]',
    eyebrow: 'text-[color:oklch(0.52_0.16_25)] dark:text-[color:oklch(0.76_0.13_25)]',
  },
} as const;

const current = variants[type];
const heading = title ?? current.label;
---

<aside
  class:list={[
    'my-6 grid grid-cols-[0.375rem_minmax(0,1fr)] overflow-hidden rounded-[var(--lotus-radius-lg)] border',
    current.wrapper,
  ]}
>
  <div class:list={['h-full', current.rail]} aria-hidden="true" />
  <div class="px-5 py-4">
    <p class:list={['text-xs font-semibold uppercase', current.eyebrow]}>{current.label}</p>
    <div class="mt-2 space-y-3 text-sm leading-7 text-[var(--lotus-fg)]">
      <p class="text-base font-semibold leading-6 text-[var(--lotus-fg)]">{heading}</p>
      <div class="space-y-3">
        <slot />
      </div>
    </div>
  </div>
</aside>
