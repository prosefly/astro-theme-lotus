---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<li class="relative list-none">
  <span
    class="absolute -left-[2.05rem] top-1.5 h-3 w-3 rounded-full border-2 border-[var(--lotus-bg)] bg-[var(--lotus-accent)]"
    aria-hidden="true"
  />
  <div class="space-y-3">
    <h3 class="m-0 text-xl font-semibold leading-7 text-[var(--lotus-fg)]">{title}</h3>
    <div class="space-y-3 text-base leading-7 text-[var(--lotus-muted)]">
      <slot />
    </div>
  </div>
</li>
