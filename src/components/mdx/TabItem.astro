---
interface Props {
  label: string;
  value: string;
}

const { label, value } = Astro.props;
---

<section
  class="rounded-[var(--lotus-radius-md)] border border-[var(--lotus-border)] bg-[var(--lotus-bg)] p-4"
  data-tab-value={value}
>
  <div class="mb-3 inline-flex items-center rounded-[var(--lotus-radius-full,var(--lotus-radius-md))] border border-[var(--lotus-border)] bg-[var(--lotus-muted-bg)] px-3 py-1 text-sm font-semibold text-[var(--lotus-fg)]">
    {label}
  </div>
  <div class="text-sm leading-7 text-[var(--lotus-muted)]">
    <slot />
  </div>
</section>
