---
import type { MarkdownHeading } from 'astro';
import { render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import {
  getDocsEntries,
  getDocsNavigation,
  getEntrySection,
  getSidebarNavigation,
  getSidebarSectionTitle,
} from '../../lib/docs';

export async function getStaticPaths() {
  const entries = await getDocsEntries();

  return entries.map((entry) => ({
    params: { slug: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const currentSection = getEntrySection(entry);
const subnav = await getDocsNavigation(currentSection);
const sidebar = await getSidebarNavigation(currentSection);
const sidebars = Object.fromEntries(
  await Promise.all(
    subnav.map(async (section) => [section.slug, await getSidebarNavigation(section.slug)]),
  ),
);
const sectionTitle = getSidebarSectionTitle(sidebar, entry.id);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sectionTitle={sectionTitle}
  currentSlug={entry.id}
  subnav={subnav}
  sidebar={sidebar}
  sidebars={sidebars}
  headings={headings as MarkdownHeading[]}
>
  <Content />
</DocsLayout>
