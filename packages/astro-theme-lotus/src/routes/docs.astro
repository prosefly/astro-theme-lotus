---
import type { MarkdownHeading } from 'astro';
import { render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import {
  getDocsEntries,
  getDocsNavigation,
  getEntrySlug,
  getEntrySection,
  getSidebarNavigation,
  getSidebarPagination,
  getSidebarSectionTitle,
} from '../lib/docs';

function getTableOfContentsHeadings(
  headings: MarkdownHeading[],
  tableOfContents: false | { minHeadingLevel?: number; maxHeadingLevel?: number } | undefined,
): MarkdownHeading[] {
  if (tableOfContents === false) {
    return [];
  }

  const minHeadingLevel = tableOfContents?.minHeadingLevel ?? 2;
  const maxHeadingLevel = tableOfContents?.maxHeadingLevel ?? 3;

  return headings.filter(
    (heading) => heading.depth >= minHeadingLevel && heading.depth <= maxHeadingLevel,
  );
}

export async function getStaticPaths() {
  const entries = await getDocsEntries();

  return entries.map((entry) => ({
    params: { slug: getEntrySlug(entry) === 'index' ? undefined : getEntrySlug(entry) },
    props: { entry, currentSection: getEntrySection(entry, entries) },
  }));
}

const { entry, currentSection } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = getTableOfContentsHeadings(
  headings as MarkdownHeading[],
  entry.data.tableOfContents,
);
const subnav = await getDocsNavigation(currentSection);
const sidebar = await getSidebarNavigation(currentSection);
const sidebars = Object.fromEntries(
  await Promise.all(
    subnav.map(async (section) => [section.slug, await getSidebarNavigation(section.slug)]),
  ),
);
const sectionTitle = getSidebarSectionTitle(sidebar, entry.id);
const pageNavigation = getSidebarPagination(sidebar, entry.id, {
  previous: entry.data.prev,
  next: entry.data.next,
});
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sectionTitle={sectionTitle}
  currentSlug={getEntrySlug(entry)}
  lastUpdated={entry.data.lastUpdated}
  pageNavigation={pageNavigation}
  subnav={subnav}
  sidebar={sidebar}
  sidebars={sidebars}
  headings={tocHeadings}
>
  <Content />
</DocsLayout>
