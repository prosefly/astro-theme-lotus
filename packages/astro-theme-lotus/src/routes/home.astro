---
import { getCollection, render } from 'astro:content';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import SplashLayout from '../layouts/SplashLayout.astro';
import TextLayout from '../layouts/TextLayout.astro';
import { getDefaultLocale } from '../lib/i18n';
import type { LotusThemeConfig } from '../lib/theme';

const themeConfig = rawThemeConfig as LotusThemeConfig;
const entries = await getCollection('docs');
const entry = entries.find(
  (candidate) =>
    candidate.id === 'index' &&
    (!import.meta.env.PROD || !candidate.data.draft),
);

if (!entry) {
  throw new Error(
    '[Lotus] The homepage route requires src/content/index.mdx to be included in the docs collection.',
  );
}

const { Content } = await render(entry);
const currentLocale = getDefaultLocale(themeConfig);
const isSplashTemplate = entry.data.template === 'splash';
---

{isSplashTemplate ? (
  <SplashLayout title={entry.data.title} description={entry.data.description} hero={entry.data.hero} locale={currentLocale} pagefind={entry.data.pagefind}>
    <Content />
  </SplashLayout>
) : (
  <TextLayout title={entry.data.title} description={entry.data.description} locale={currentLocale} pagefind={entry.data.pagefind}>
    <Content />
  </TextLayout>
)}
