---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/layout/Footer.astro';
import MainHeader from '../components/layout/MainHeader.astro';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { normalizeDocsBasePath, type LotusThemeConfig } from '../lib/theme';

const themeConfig = rawThemeConfig as LotusThemeConfig;
const docsBasePath = normalizeDocsBasePath(themeConfig.docsBase);
const docsHref = docsBasePath === '/' ? '/' : `${docsBasePath}/`;

Astro.response.status = 404;
---

<BaseLayout
  title="Page not found"
  description={`The page could not be found on ${themeConfig.name}.`}
>
  <MainHeader surface />

  <main class="mx-auto flex min-h-[calc(100vh-var(--lotus-header-height)-16rem)] max-w-screen-2xl items-center justify-center px-4 py-20 text-center sm:px-6">
    <div class="max-w-xl">
      <p class="mb-4 text-sm font-semibold text-(--lotus-accent)">404</p>
      <h1 class="text-4xl font-semibold tracking-normal text-(--lotus-text-strong)">
        Page not found
      </h1>
      <p class="mt-4 text-base leading-7 text-(--lotus-text-muted)">
        The page you are looking for does not exist or has moved.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          class="lotus-focus-ring inline-flex h-10 items-center justify-center rounded-(--lotus-radius-md) bg-(--lotus-accent) px-4 text-sm font-medium text-(--lotus-accent-contrast) transition-opacity hover:opacity-90"
          href={docsHref}
        >
          Open documentation
        </a>
        <a
          class="lotus-focus-ring inline-flex h-10 items-center justify-center rounded-(--lotus-radius-md) bg-(--lotus-surface) px-4 text-sm font-medium text-(--lotus-text-strong) transition-colors hover:bg-(--lotus-accent-soft)"
          href="/"
        >
          Back home
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
