---
import HeaderNavbar from 'virtual:prosefly/lotus/components/HeaderNavbar';
import HeaderSocialIcons from 'virtual:prosefly/lotus/components/HeaderSocialIcons';
import LanguageSelect from '../theme/LanguageSelect.astro';
import MobileMenu from './MobileMenu.astro';
import SearchDialog from 'virtual:prosefly/lotus/components/SearchDialog';
import SiteBrand from 'virtual:prosefly/lotus/components/SiteBrand';
import ThemeSwitch from 'virtual:prosefly/lotus/components/ThemeSwitch';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { isPagefindSearchEnabled } from '../../lib/search';
import type { LotusThemeConfig } from '../../lib/theme';

interface Props {
  currentPath?: string;
  showMobileLanguage?: boolean;
  surface?: boolean;
}

const { currentPath, showMobileLanguage = true, surface = true } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const hasMobileHeaderActions = themeConfig.search !== false || Boolean(themeConfig.assistant);
const showThemeControl = themeConfig.themeModeControl !== false;
const pagefindIgnoreAttrs = isPagefindSearchEnabled(themeConfig)
  ? { 'data-pagefind-ignore': true }
  : {};
---

<header
  class:list={[
    'relative z-40',
    'h-(--lotus-header-height)',
    surface && 'lotus-border-subtle border-b bg-(--lotus-background)/95 backdrop-blur',
  ]}
  {...pagefindIgnoreAttrs}
>
  <div class="mx-auto flex h-full max-w-screen-2xl items-center gap-4 px-4 sm:px-6">
    <SiteBrand fetchPriority="high" markIdPrefix="lotus-header-brand" />

    <SearchDialog />

    <div class="ms-auto hidden min-w-0 items-center gap-5 lg:flex">
      <HeaderNavbar currentPath={currentPath} />

      <div class="flex items-center gap-2">
        <div class="lotus-border-subtle h-5 border-s"></div>
        <HeaderSocialIcons />
        <LanguageSelect />
        {showThemeControl && <ThemeSwitch />}
      </div>
    </div>

    <MobileMenu
      class={hasMobileHeaderActions ? undefined : 'ms-auto'}
      currentPath={currentPath}
      showLanguage={showMobileLanguage}
      showThemeSwitch={showThemeControl}
    />
  </div>
</header>
