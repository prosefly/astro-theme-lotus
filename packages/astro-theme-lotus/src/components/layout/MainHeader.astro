---
import { Icon } from '@prosefly/astro-components';
import Button from '../ui/Button.astro';
import MobileMenu from './MobileMenu.astro';
import SearchDialog from './SearchDialog.astro';
import ThemeSwitch from './ThemeSwitch.astro';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { resolveIconName } from '../../lib/icons';
import { normalizeDocsBasePath, type LotusThemeConfig } from '../../lib/theme';

interface Props {
  currentPath?: string;
  surface?: boolean;
}

const { currentPath, surface = true } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const actions = themeConfig.actions ?? [];
const socials = themeConfig.socials ?? [];
const docsBasePath = normalizeDocsBasePath(themeConfig.docs.basePath);
const docsRootHref = docsBasePath === '/' ? '/' : `${docsBasePath}/`;

function normalizeHref(href: string): string {
  return href.endsWith('/') ? href : `${href}/`;
}

function isActive(href: string): boolean {
  if (!currentPath) {
    return false;
  }

  if (normalizeHref(href) === docsRootHref) {
    return currentPath === docsRootHref || currentPath.startsWith(docsRootHref);
  }

  return currentPath === href || currentPath.startsWith(`${href}`);
}

function getActionLabel(label: string, icon?: string): string {
  return icon ? `${label} (${icon})` : label;
}

---

<header
  class:list={[
    'h-[var(--lotus-header-height)]',
    surface && 'lotus-border-subtle border-b bg-[var(--lotus-background)]/95 backdrop-blur',
  ]}
>
  <div class="mx-auto flex h-full max-w-screen-2xl items-center gap-4 px-4 sm:px-6">
    <a class="lotus-focus-ring flex min-w-0 items-center gap-3 text-[var(--lotus-text)]" href="/">
      <img alt="" class="h-8 w-8 rounded-[var(--lotus-radius-md)]" src={themeConfig.site.logo} />
      <span class="truncate text-sm font-semibold sm:text-base">{themeConfig.site.title}</span>
    </a>

    <SearchDialog />

    <div class="ml-auto hidden min-w-0 items-center gap-5 lg:flex">
      <nav aria-label="Primary" class="flex min-w-0 items-center gap-5">
        {themeConfig.nav.map((item) => (
          <a
            class="lotus-focus-ring text-sm font-medium text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text)]"
            aria-current={isActive(item.href) ? 'page' : undefined}
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </nav>

      {actions.length > 0 && (
        <div class="flex items-center gap-2">
          {actions.map((action) => (
            <Button
              color={action.color ?? 'neutral'}
              external={action.external}
              href={action.href}
              variant={action.variant ?? 'soft'}
            >
              {action.label}
            </Button>
          ))}
        </div>
      )}

      <div class="flex items-center gap-2">
        <div class="lotus-border-subtle h-5 border-l"></div>
        {socials.map((social) => (
          <a
            aria-label={getActionLabel(social.label, social.icon)}
            class="lotus-focus-ring inline-flex h-9 w-9 items-center justify-center rounded-[var(--lotus-radius-md)] text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text)]"
            href={social.href}
            rel={social.external ? 'noreferrer' : undefined}
            target={social.external ? '_blank' : undefined}
          >
            <Icon name={resolveIconName(social.icon)} />
          </a>
        ))}
        <ThemeSwitch />
      </div>
    </div>

    <MobileMenu currentPath={currentPath} />
  </div>
</header>
