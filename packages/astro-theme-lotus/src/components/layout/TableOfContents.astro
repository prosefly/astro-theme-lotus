---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{
  visibleHeadings.length > 0 && (
    <nav aria-label="On this page" class="space-y-2">
      <p class="text-[0.8125rem] font-semibold leading-5 text-[var(--lotus-text)]">On this page</p>
      <ul class="lotus-border-muted space-y-0.5 border-l">
        {visibleHeadings.map((heading) => (
          <li>
            <a
              class:list={[
                'lotus-focus-ring lotus-toc-link -ml-px block border-l-2 py-1.5 pr-2 text-[0.8125rem] leading-5 transition-colors',
                heading.depth === 3 ? 'pl-5' : 'pl-3',
                'border-transparent text-[var(--lotus-text-muted)] hover:text-[var(--lotus-text)]',
              ]}
              data-depth={heading.depth}
              data-toc-link={heading.slug}
              href={`#${heading.slug}`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script is:inline>
  (() => {
    const links = Array.from(document.querySelectorAll('a[data-toc-link]'));

    if (!links.length || !('IntersectionObserver' in window)) {
      return;
    }

    const headings = links
      .map((link) => {
        const slug = link.getAttribute('data-toc-link');
        const heading = slug ? document.getElementById(slug) : null;

        return heading ? { heading, slug } : null;
      })
      .filter(Boolean);

    if (!headings.length) {
      return;
    }

    const fallbackSlug = links[0].getAttribute('data-toc-link') ?? headings[0].slug;

    const setActiveLink = (activeSlug) => {
      links.forEach((link) => {
        if (link.getAttribute('data-toc-link') === activeSlug) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const getClosestHeadingSlug = () => {
      const chromeHeight = getComputedStyle(document.documentElement)
        .getPropertyValue('--lotus-docs-chrome-height')
        .trim();
      const parsedChromeHeight = Number.parseFloat(chromeHeight);
      const offset = Number.isFinite(parsedChromeHeight) ? parsedChromeHeight + 24 : 120;

      for (let index = headings.length - 1; index >= 0; index -= 1) {
        if (headings[index].heading.getBoundingClientRect().top <= offset) {
          return headings[index].slug;
        }
      }

      return fallbackSlug;
    };

    const observer = new IntersectionObserver(
      () => {
        setActiveLink(getClosestHeadingSlug());
      },
      {
        rootMargin: '-30% 0px -60% 0px',
        threshold: 0,
      },
    );

    headings.forEach(({ heading }) => observer.observe(heading));
    setActiveLink(getClosestHeadingSlug());
  })();
</script>
