---
import { Icon } from '@prosefly/astro-components';
import Button from '../ui/Button.astro';
import ThemeSwitch from 'virtual:prosefly/lotus/components/ThemeSwitch';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { resolveIconName } from '../../lib/icons';
import { normalizeDocsBasePath, type LotusThemeConfig } from '../../lib/theme';

interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const navigation = themeConfig.navigation ?? [];
const socials = themeConfig.socials ?? [];
const docsBasePath = normalizeDocsBasePath(themeConfig.docsBase);
const docsRootHref = docsBasePath === '/' ? '/' : `${docsBasePath}/`;

function normalizeHref(href: string): string {
  return href.endsWith('/') ? href : `${href}/`;
}

function isActive(href: string): boolean {
  if (!currentPath) {
    return false;
  }

  if (normalizeHref(href) === docsRootHref) {
    return currentPath === docsRootHref || currentPath.startsWith(docsRootHref);
  }

  return currentPath === href || currentPath.startsWith(`${href}`);
}

function isNavigationButton(item: LotusThemeConfig['navigation'][number]): boolean {
  return Boolean(item.variant);
}

---

<details class="group relative lg:hidden">
  <summary class="lotus-focus-ring lotus-border-muted flex h-10 items-center rounded-[var(--lotus-radius-md)] border px-3 text-sm font-medium text-[var(--lotus-text-strong)] marker:hidden">
    Menu
  </summary>

  <div class="lotus-border-muted absolute right-0 top-[calc(100%+0.75rem)] z-50 w-72 rounded-[var(--lotus-radius-lg)] border bg-[var(--lotus-background)] p-4 shadow-lg shadow-black/5">
    <nav aria-label="Primary" class="space-y-4">
      <div class="space-y-1">
        {navigation.map((item) => (
          isNavigationButton(item) ? (
            <Button
              block
              color={item.color ?? 'neutral'}
              external={item.external}
              href={item.href}
              trailingIcon={item.trailingIcon}
              variant={item.variant}
            >
              {item.label}
            </Button>
          ) : (
            <a
              class="lotus-focus-ring flex items-center gap-1.5 rounded-[var(--lotus-radius-md)] px-3 py-2 text-sm font-medium text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text-strong)]"
              aria-current={isActive(item.href) ? 'page' : undefined}
              href={item.href}
              rel={item.external ? 'noreferrer' : undefined}
              target={item.external ? '_blank' : undefined}
            >
              <span>{item.label}</span>
              {item.trailingIcon && (
                <Icon aria-hidden="true" class="h-4 w-4" name={resolveIconName(item.trailingIcon)} />
              )}
            </a>
          )
        ))}
      </div>

      <div class="lotus-border-subtle flex items-center justify-between gap-3 border-t pt-4">
        <div class="flex items-center gap-1">
          {socials.map((social) => (
            <a
              aria-label={social.label}
              class="lotus-focus-ring inline-flex h-9 w-9 items-center justify-center rounded-[var(--lotus-radius-md)] text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text-strong)]"
              href={social.href}
              target={social.external ? '_blank' : undefined}
              rel={social.external ? 'noreferrer' : undefined}
            >
              <Icon name={resolveIconName(social.icon)} />
            </a>
          ))}
        </div>
        <ThemeSwitch />
      </div>
    </nav>
  </div>
</details>
