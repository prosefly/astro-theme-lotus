---
import { Icon } from '@prosefly/astro-components';
import ThemeSwitch from './ThemeSwitch.astro';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { normalizeDocsBasePath, type LotusThemeConfig } from '../../lib/theme';

interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const actions = themeConfig.actions ?? [];
const socials = themeConfig.socials ?? [];
const docsBasePath = normalizeDocsBasePath(themeConfig.docs.basePath);
const docsRootHref = docsBasePath === '/' ? '/' : `${docsBasePath}/`;

function normalizeHref(href: string): string {
  return href.endsWith('/') ? href : `${href}/`;
}

function isActive(href: string): boolean {
  if (!currentPath) {
    return false;
  }

  if (normalizeHref(href) === docsRootHref) {
    return currentPath === docsRootHref || currentPath.startsWith(docsRootHref);
  }

  return currentPath === href || currentPath.startsWith(`${href}`);
}

function getActionClass(action: (typeof actions)[number]): string {
  const variant = action.variant ?? 'soft';
  const color = action.color ?? 'neutral';
  const base =
    'lotus-focus-ring flex h-9 items-center rounded-[var(--lotus-radius-md)] px-3 text-sm font-medium transition-colors';

  if (variant === 'solid') {
    return color === 'accent'
      ? `${base} bg-[var(--lotus-accent)] text-[var(--lotus-accent-contrast)] hover:opacity-90`
      : `${base} bg-[var(--lotus-text)] text-[var(--lotus-background)] hover:opacity-90`;
  }

  if (variant === 'outline') {
    return color === 'accent'
      ? `${base} lotus-border-muted border text-[var(--lotus-accent)] hover:border-[var(--lotus-accent)] hover:bg-[var(--lotus-accent-soft)]`
      : `${base} lotus-border-muted border text-[var(--lotus-text)] hover:bg-[var(--lotus-surface)]`;
  }

  return color === 'accent'
    ? `${base} bg-[var(--lotus-accent-soft)] text-[var(--lotus-accent)] hover:opacity-90`
    : `${base} bg-[var(--lotus-surface)] text-[var(--lotus-text)] hover:bg-[var(--lotus-accent-soft)]`;
}

function getIconName(icon?: string): string {
  if (!icon) {
    return 'lucide:external-link';
  }

  if (icon.includes(':')) {
    return icon;
  }

  const aliases: Record<string, string> = {
    bluesky: 'simple-icons:bluesky',
    discord: 'simple-icons:discord',
    external: 'lucide:external-link',
    github: 'simple-icons:github',
    x: 'simple-icons:x',
  };

  return aliases[icon] ?? icon;
}
---

<details class="group relative lg:hidden">
  <summary class="lotus-focus-ring lotus-border-muted flex h-10 items-center rounded-[var(--lotus-radius-md)] border px-3 text-sm font-medium text-[var(--lotus-text)] marker:hidden">
    Menu
  </summary>

  <div class="lotus-border-muted absolute right-0 top-[calc(100%+0.75rem)] z-50 w-72 rounded-[var(--lotus-radius-lg)] border bg-[var(--lotus-background)] p-4 shadow-lg shadow-black/5">
    <nav aria-label="Primary" class="space-y-4">
      <div class="space-y-1">
        {themeConfig.nav.map((item) => (
          <a
            class="lotus-focus-ring block rounded-[var(--lotus-radius-md)] px-3 py-2 text-sm font-medium text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text)]"
            aria-current={isActive(item.href) ? 'page' : undefined}
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </div>

      {actions.length > 0 && (
        <div class="lotus-border-subtle border-t pt-4">
          <div class="mt-2 space-y-2">
            {actions.map((action) => (
              <a
                class={getActionClass(action)}
                href={action.href}
                target={action.external ? '_blank' : undefined}
                rel={action.external ? 'noreferrer' : undefined}
              >
                {action.label}
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="lotus-border-subtle flex items-center justify-between gap-3 border-t pt-4">
        <div class="flex items-center gap-1">
          {socials.map((social) => (
            <a
              aria-label={social.label}
              class="lotus-focus-ring inline-flex h-9 w-9 items-center justify-center rounded-[var(--lotus-radius-md)] text-[var(--lotus-text-muted)] transition-colors hover:text-[var(--lotus-text)]"
              href={social.href}
              target={social.external ? '_blank' : undefined}
              rel={social.external ? 'noreferrer' : undefined}
            >
              <Icon name={getIconName(social.icon)} />
            </a>
          ))}
        </div>
        <ThemeSwitch />
      </div>
    </nav>
  </div>
</details>
