---
import { Icon } from '@prosefly/astro-components';
import ThemeModeController from './ThemeModeController.astro';

const t = Astro.locals.t;
---

<div
  aria-label={t('themeSelect.accessibleLabel')}
  class="lotus-border-muted grid h-9 grid-cols-2 rounded-full border p-0.5 flex items-center"
  data-lotus-theme-switch
  data-theme-label-dark={t('themeSelect.dark')}
  data-theme-label-light={t('themeSelect.light')}
  data-theme-label-system={t('themeSelect.auto')}
  role="group"
>
  <button
    aria-label={t('themeSelect.lightTheme')}
    class="lotus-focus-ring inline-flex h-7 w-7 items-center justify-center rounded-full text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
    data-theme-mode="light"
    title={t('themeSelect.lightTheme')}
    type="button"
  >
    <Icon aria-hidden="true" class="block h-3.5 w-3.5" name="lucide:sun" />
  </button>
  <button
    aria-label={t('themeSelect.darkTheme')}
    class="lotus-focus-ring inline-flex h-7 w-7 items-center justify-center rounded-full text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
    data-theme-mode="dark"
    title={t('themeSelect.darkTheme')}
    type="button"
  >
    <Icon aria-hidden="true" class="block h-3.5 w-3.5" name="lucide:moon" />
  </button>
</div>

<ThemeModeController />
