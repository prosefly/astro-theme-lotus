<dialog
  aria-label="Search documentation"
  class="lotus-search-dialog lotus-border-muted w-[min(42rem,calc(100vw-2rem))] rounded-(--lotus-radius-lg) border bg-(--lotus-background) p-0 text-(--lotus-text) shadow-xl shadow-black/10"
  data-lotus-search-dialog
>
  <form class="lotus-border-subtle flex h-14 items-center gap-3 border-b px-4" data-lotus-search-form>
    <svg aria-hidden="true" class="h-4 w-4 shrink-0 text-(--lotus-text-muted)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
      <circle cx="11" cy="11" r="7" />
      <path d="m20 20-3.5-3.5" />
    </svg>
    <input
      aria-label="Search documentation"
      class="min-w-0 flex-1 bg-transparent text-base outline-none placeholder:text-(--lotus-text-muted)"
      data-lotus-search-input
      placeholder="Search docs"
      type="search"
    />
    <button
      aria-label="Close search"
      class="lotus-focus-ring inline-flex h-8 w-8 items-center justify-center rounded-(--lotus-radius-md) text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
      data-lotus-search-close
      type="button"
    >
      <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>
  </form>
  <div class="px-4 py-10 text-center text-sm text-(--lotus-text-muted)">
    No results
  </div>
</dialog>

<script is:inline>
  (() => {
    if (window.__lotusSearchDialogReady) {
      return;
    }

    window.__lotusSearchDialogReady = true;

    const initSearchDialog = () => {
      const dialog = document.querySelector('[data-lotus-search-dialog]');
      const input = dialog?.querySelector('[data-lotus-search-input]');
      const triggers = Array.from(document.querySelectorAll('[data-lotus-search-trigger]'));

      if (!dialog || !input || !triggers.length) {
        return;
      }

      const openDialog = () => {
        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
          dialog.setAttribute('open', '');
        }

        window.setTimeout(() => input.focus(), 0);
      };

      const closeDialog = () => {
        if (typeof dialog.close === 'function') {
          dialog.close();
        } else {
          dialog.removeAttribute('open');
        }
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', openDialog);
      });

      dialog.querySelector('[data-lotus-search-close]')?.addEventListener('click', closeDialog);
      dialog.querySelector('[data-lotus-search-form]')?.addEventListener('submit', (event) => {
        event.preventDefault();
      });

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSearchDialog, { once: true });
    } else {
      initSearchDialog();
    }
  })();
</script>
