---
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import DocSearchDialogContent from './DocSearchDialogContent.astro';
import LocalSearchDialogContent from './LocalSearchDialogContent.astro';
import type { LotusThemeConfig } from '../../lib/theme';

const themeConfig = rawThemeConfig as LotusThemeConfig;
const searchConfig = themeConfig.search === false ? undefined : themeConfig.search;
const searchProvider = searchConfig?.provider ?? 'local';
---

{searchConfig && (
  searchProvider === 'docsearch'
    ? <DocSearchDialogContent />
    : <LocalSearchDialogContent />
)}
