---
const t = Astro.locals.t;
---

<button
  aria-label={t('search.label')}
  class="lotus-focus-ring ml-auto inline-flex h-10 w-10 items-center justify-center rounded-(--lotus-radius-md) text-(--lotus-text-muted) transition-colors hover:bg-(--lotus-surface) hover:text-(--lotus-text-strong) lg:ml-0 lg:border lg:border-(--lotus-border-muted) lg:hover:bg-transparent xl:hidden"
  data-lotus-search-trigger
  type="button"
>
  <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
    <circle cx="11" cy="11" r="7" />
    <path d="m20 20-3.5-3.5" />
  </svg>
</button>

<button
  class="lotus-focus-ring lotus-border-muted hidden h-9 w-64 min-w-0 items-center gap-2 rounded-(--lotus-radius-md) border px-3 text-left text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong) xl:flex"
  data-lotus-search-trigger
  type="button"
>
  <svg aria-hidden="true" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
    <circle cx="11" cy="11" r="7" />
    <path d="m20 20-3.5-3.5" />
  </svg>
  <span class="min-w-0 flex-1 text-sm">{t('search.triggerLabel')}</span>
</button>
