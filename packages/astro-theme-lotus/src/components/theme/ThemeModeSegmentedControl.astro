---
import { Icon } from '@prosefly/astro-components';
import ThemeModeController from './ThemeModeController.astro';

const t = Astro.locals.t;
const modes = [
  { value: 'system', label: t('themeSelect.auto') },
  { value: 'light', label: t('themeSelect.light') },
  { value: 'dark', label: t('themeSelect.dark') },
];
---

<div
  class="lotus-border-muted flex h-9 items-center rounded-(--lotus-radius-md) border p-0.5"
  data-lotus-theme-switch
  data-theme-label-dark={t('themeSelect.dark')}
  data-theme-label-light={t('themeSelect.light')}
  data-theme-label-system={t('themeSelect.auto')}
>
  {modes.map((mode) => (
    <button
      aria-label={`${mode.label} theme`}
      class="lotus-focus-ring inline-flex h-7 w-7 items-center justify-center rounded-[calc(var(--lotus-radius-md)-2px)] text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
      data-theme-mode={mode.value}
      title={`${mode.label} theme`}
      type="button"
    >
      {mode.value === 'light' ? (
        <Icon aria-hidden="true" class="block h-3.5 w-3.5" name="lucide:sun" />
      ) : mode.value === 'dark' ? (
        <Icon aria-hidden="true" class="block h-3.5 w-3.5" name="lucide:moon" />
      ) : (
        <Icon aria-hidden="true" class="block h-3.5 w-3.5" name="lucide:monitor" />
      )}
    </button>
  ))}
</div>

<ThemeModeController />
