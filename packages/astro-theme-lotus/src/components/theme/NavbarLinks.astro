---
import Button from '../ui/Button.astro';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import { normalizeDocsBasePath } from '../../lib/config';
import { localizeDocsHref, translateLabel } from '../../lib/i18n';
import type { LotusThemeConfig } from '../../lib/theme';

interface Props {
  currentPath?: string;
  mobile?: boolean;
}

const { currentPath, mobile = false } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const navbar = themeConfig.navbar ?? [];
const docsBasePath = normalizeDocsBasePath(themeConfig.docsBase);
const docsRootHref = docsBasePath === '/' ? '/' : `${docsBasePath}/`;
const t = Astro.locals.t;
const currentLocale = t.locale();

function normalizeHref(href: string): string {
  return href.endsWith('/') ? href : `${href}/`;
}

function isActive(href: string): boolean {
  if (!currentPath) {
    return false;
  }

  if (normalizeHref(href) === docsRootHref) {
    return currentPath === docsRootHref || currentPath.startsWith(docsRootHref);
  }

  return currentPath === href || currentPath.startsWith(`${href}`);
}

---

<nav
  aria-label={t('navbar.primary')}
  class:list={[
    mobile ? 'space-y-1' : 'flex min-w-0 items-center gap-5',
  ]}
>
  {navbar.map((item) => (
    <Button
      aria-current={isActive(item.external ? item.href : localizeDocsHref(themeConfig, item.href, currentLocale.key)) ? 'page' : undefined}
      block={mobile}
      class={(item.variant ?? 'text') === 'text' && mobile ? 'px-3 py-2' : undefined}
      color={item.color ?? 'neutral'}
      data-lotus-dropdown-close={mobile ? true : undefined}
      external={item.external}
      href={item.external ? item.href : localizeDocsHref(themeConfig, item.href, currentLocale.key)}
      trailingIcon={item.trailingIcon}
      variant={item.variant ?? 'text'}
    >
      {translateLabel(item.label, item.translations, currentLocale.key)}
    </Button>
  ))}
</nav>
