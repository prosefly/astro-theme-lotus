---
import ThemeModeController from './ThemeModeController.astro';

const t = Astro.locals.t;
const modes = [
  { value: 'system', label: t('themeSelect.auto') },
  { value: 'light', label: t('themeSelect.light') },
  { value: 'dark', label: t('themeSelect.dark') },
];
---

<div
  class="relative"
  data-lotus-theme-switch
  data-theme-label-dark={t('themeSelect.dark')}
  data-theme-label-light={t('themeSelect.light')}
  data-theme-label-system={t('themeSelect.auto')}
>
  <select
    aria-label={t('themeSelect.accessibleLabel')}
    class="lotus-focus-ring lotus-border-muted h-9 rounded-(--lotus-radius-md) border bg-(--lotus-background) px-3 text-sm font-medium text-(--lotus-text-strong) sm:hidden"
    data-theme-select
  >
    {modes.map((mode) => (
      <option value={mode.value}>{mode.label}</option>
    ))}
  </select>

  <details class="group/theme-select relative hidden sm:block">
    <summary class="lotus-focus-ring lotus-border-muted flex h-9 cursor-pointer items-center gap-2 rounded-(--lotus-radius-md) border px-3 text-sm font-medium text-(--lotus-text-strong) marker:hidden">
      <span data-theme-current>{t('themeSelect.auto')}</span>
      <svg aria-hidden="true" class="h-3.5 w-3.5 text-(--lotus-text-muted) transition-transform group-open/theme-select:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </summary>
    <div class="lotus-border-muted absolute right-0 top-[calc(100%+0.5rem)] z-50 min-w-32 rounded-[min(var(--lotus-radius-lg),1rem)] border bg-(--lotus-background) p-1 shadow-lg shadow-black/5">
      {modes.map((mode) => (
        <button
          class="lotus-focus-ring flex w-full items-center rounded-[calc(var(--lotus-radius-md)-2px)] px-2.5 py-1.5 text-left text-sm text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
          data-theme-mode={mode.value}
          type="button"
        >
          {mode.label}
        </button>
      ))}
    </div>
  </details>
</div>

<ThemeModeController />
