---
import { Icon } from '@prosefly/astro-components';
import ThemeModeController from './ThemeModeController.astro';

const t = Astro.locals.t;
---

<div
  data-lotus-theme-switch
  data-theme-label-dark={t('themeSelect.dark')}
  data-theme-label-light={t('themeSelect.light')}
  data-theme-label-system={t('themeSelect.auto')}
>
  <button
    aria-label={t('themeSelect.cycle')}
    class="lotus-focus-ring lotus-border-muted inline-flex h-9 w-9 items-center justify-center rounded-(--lotus-radius-md) border text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
    data-theme-cycle
    title={t('themeSelect.cycle')}
    type="button"
  >
    <span data-theme-mode-icon="system">
      <Icon aria-hidden="true" class="block h-4 w-4" name="lucide:monitor" />
    </span>
    <span data-theme-mode-icon="light" hidden>
      <Icon aria-hidden="true" class="block h-4 w-4" name="lucide:sun" />
    </span>
    <span data-theme-mode-icon="dark" hidden>
      <Icon aria-hidden="true" class="block h-4 w-4" name="lucide:moon" />
    </span>
  </button>
</div>

<ThemeModeController />
