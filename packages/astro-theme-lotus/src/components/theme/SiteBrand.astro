---
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import type { LotusThemeConfig } from '../../lib/theme';
import LotusMark from './LotusMark.astro';

interface Props {
  class?: string;
  fetchPriority?: 'high' | 'low' | 'auto';
  markIdPrefix?: string;
  textClass?: string;
}

const {
  class: className,
  fetchPriority,
  markIdPrefix = 'lotus-site-brand',
  textClass = 'truncate text-sm font-semibold sm:text-base',
} = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const logo = themeConfig.logo;
const logoHref = !logo || typeof logo === 'string' ? '/' : (logo.href ?? '/');
const logoLight = typeof logo === 'string' ? logo : logo?.light;
const logoDark = typeof logo === 'string' ? undefined : logo?.dark;
const logoVariant = typeof logo === 'object' ? logo.variant ?? 'mark' : 'mark';
const logoHasText = logoVariant === 'lockup';
const logoAlt = logoHasText ? themeConfig.name : '';
---

<a
  class:list={[
    'lotus-focus-ring flex min-w-0 items-center gap-3 text-(--lotus-text-strong)',
    className,
  ]}
  href={logoHref}
>
  <span
    class:list={[
      'relative h-8 shrink-0',
      logoHasText ? 'max-w-40' : 'w-8',
    ]}
  >
    {logoLight ? (
      <img
        alt={logoAlt}
        class:list={[
          logoHasText
            ? 'block h-8 max-w-40 object-contain'
            : 'block h-8 w-8 rounded-(--lotus-radius-md)',
          logoDark && 'lotus-logo-light',
        ]}
        fetchpriority={fetchPriority}
        src={logoLight}
      />
    ) : (
      <LotusMark class="h-8 w-8 rounded-(--lotus-radius-md)" idPrefix={markIdPrefix} />
    )}
    {logoLight && logoDark && (
      <img
        alt={logoAlt}
        class:list={[
          'lotus-logo-dark h-8',
          logoHasText
            ? 'max-w-40 object-contain'
            : 'w-8 rounded-(--lotus-radius-md)',
        ]}
        fetchpriority={fetchPriority}
        src={logoDark}
      />
    )}
  </span>
  {!logoHasText && <span class={textClass}>{themeConfig.name}</span>}
</a>

<style>
  .lotus-logo-dark {
    display: none;
  }

  :global(:root[data-theme="dark"]) .lotus-logo-light {
    display: none;
  }

  :global(:root[data-theme="dark"]) .lotus-logo-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root[data-theme="system"]) .lotus-logo-light {
      display: none;
    }

    :global(:root[data-theme="system"]) .lotus-logo-dark {
      display: block;
    }
  }
</style>
