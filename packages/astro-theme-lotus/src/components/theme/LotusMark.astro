    <linearGradient id={`${idPrefix}-d`} x1="43" x2="33" y1="16" y2="38" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#c7d2fe" />
      <stop offset="1" stop-color="#818cf8" />
