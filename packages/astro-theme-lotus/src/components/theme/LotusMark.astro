  <g transform="translate(-8 -6) scale(1.25)">
    <path fill={`url(#${idPrefix}-b)`} d="M32 10.5c-3.9 3.7-5.9 8-5.9 13 0 4.3 2 7.7 5.9 10.2 3.9-2.5 5.9-5.9 5.9-10.2 0-5-2-9.3-5.9-13" />
    <path fill={`url(#${idPrefix}-c)`} d="M25.4 16.8c-4.2 3.1-6.6 7.5-6.6 12.2q0 5.7 5.7 9 5.55-3 7.5-9.3c-3.2-2.1-5.4-6-6.6-11.9" />
    <path fill={`url(#${idPrefix}-d)`} d="M38.6 16.8c-1.2 5.9-3.4 9.8-6.6 11.9q1.95 6.3 7.5 9.3 5.7-3.3 5.7-9c0-4.7-2.4-9.1-6.6-12.2" />
    <path fill={`url(#${idPrefix}-e)`} d="M18.2 24.3c-4.4 3.6-6.6 7.4-6.6 11.3 0 3.2 1.7 5.7 5 7.4q7.5-1.95 11.7-8.4c-4.2-1.5-7.6-4.9-10.1-10.3" />
    <path fill={`url(#${idPrefix}-f)`} d="M45.8 24.3c-2.5 5.4-5.9 8.8-10.1 10.3q4.2 6.45 11.7 8.4c3.3-1.7 5-4.2 5-7.4 0-3.9-2.2-7.7-6.6-11.3" />
