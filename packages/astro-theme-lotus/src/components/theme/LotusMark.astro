    <linearGradient id={`${idPrefix}-e`} x1="13" x2="28" y1="25" y2="43" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#a5b4fc" />
      <stop offset="1" stop-color="#4f46e5" />
