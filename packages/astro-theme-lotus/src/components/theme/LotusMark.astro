    <linearGradient id={`${idPrefix}-b`} x1="32" x2="32" y1="10" y2="37" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#fff" />
      <stop offset="1" stop-color="#dbe4ff" />
