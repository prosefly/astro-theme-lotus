---
import { Icon } from '@prosefly/astro-components';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import type { DocsPaginationNav } from '../../lib/docs';
import { getLocaleFromRouteSlug, type NormalizedLocale } from '../../lib/i18n';
import { normalizeDocsBasePath, type LotusThemeConfig } from '../../lib/theme';
import { useTranslations } from '../../lib/translations';

interface Props {
  navigation: DocsPaginationNav;
  currentLocale?: NormalizedLocale;
}

const { navigation } = Astro.props;
const themeConfig = rawThemeConfig as LotusThemeConfig;
const docsBasePath = normalizeDocsBasePath(themeConfig.docsBase);
const routeSlug = docsBasePath === '/'
  ? Astro.url.pathname
  : Astro.url.pathname.replace(new RegExp(`^${docsBasePath}`), '');
const currentLocale = Astro.props.currentLocale ?? getLocaleFromRouteSlug(themeConfig, routeSlug);
const t = useTranslations(themeConfig, currentLocale);
const { previous, next } = navigation;
---

{(previous || next) && (
  <nav aria-label={t('pageNavigation.accessibleLabel')} class="lotus-border-subtle mt-6 flex items-center justify-between gap-4 border-t pt-6">
    {previous ? (
      <a
        class="lotus-focus-ring group inline-flex min-w-0 items-center gap-1.5 rounded-(--lotus-radius-md) py-2 pr-3 text-sm font-medium text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
        href={previous.href}
      >
        <Icon
          aria-hidden="true"
          class="h-4 w-4 shrink-0 transition-transform group-hover:-translate-x-0.5"
          name="lucide:chevron-left"
        />
        <span class="truncate">{previous.label}</span>
      </a>
    ) : (
      <span></span>
    )}

    {next && (
      <a
        class="lotus-focus-ring group ml-auto inline-flex min-w-0 items-center gap-1.5 rounded-(--lotus-radius-md) py-2 pl-3 text-right text-sm font-medium text-(--lotus-text-muted) transition-colors hover:text-(--lotus-text-strong)"
        href={next.href}
      >
        <span class="truncate">{next.label}</span>
        <Icon
          aria-hidden="true"
          class="h-4 w-4 shrink-0 transition-transform group-hover:translate-x-0.5"
          name="lucide:chevron-right"
        />
      </a>
    )}
  </nav>
)}
