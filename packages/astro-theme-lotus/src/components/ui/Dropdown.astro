---
interface Props {
  class?: string;
  triggerClass?: string;
  contentClass?: string;
  triggerLabel?: string;
}

const {
  class: className,
  triggerClass,
  contentClass,
  triggerLabel,
} = Astro.props;
---

<details class:list={['group/dropdown relative open:z-50', className]} data-lotus-dropdown>
  <summary
    aria-expanded="false"
    aria-label={triggerLabel}
    aria-haspopup="true"
    class:list={[
      'list-none marker:hidden [&::-webkit-details-marker]:hidden',
      triggerClass,
    ]}
  >
    <slot name="trigger" />
  </summary>
  <div class:list={contentClass} data-lotus-dropdown-content>
    <slot />
  </div>
</details>

<script>
  import '../../client/dropdown';
</script>
