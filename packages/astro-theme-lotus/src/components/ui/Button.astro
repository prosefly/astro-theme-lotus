---
import { Icon } from '@prosefly/astro-components';
import { resolveIconName } from '../../lib/icons';

type ButtonVariant = 'soft' | 'outline' | 'solid' | 'ghost';
type ButtonColor = 'neutral' | 'accent';

interface Props {
  href?: string;
  external?: boolean;
  variant?: ButtonVariant;
  color?: ButtonColor;
  trailingIcon?: string;
  block?: boolean;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  href,
  external = false,
  variant = 'soft',
  color = 'neutral',
  trailingIcon,
  block = false,
  class: className,
  type = 'button',
} = Astro.props;
const trailingIconName = trailingIcon ? resolveIconName(trailingIcon) : undefined;
const baseClasses = [
  'lotus-focus-ring h-9 items-center justify-center gap-2 rounded-[var(--lotus-radius-md)] px-3 text-sm font-medium transition-colors',
  block ? 'flex w-full' : 'inline-flex',
];
const variantClasses = {
  solid:
    color === 'accent'
      ? 'bg-[var(--lotus-accent)] text-[var(--lotus-accent-contrast)] hover:opacity-90'
      : 'bg-[var(--lotus-text)] text-[var(--lotus-background)] hover:opacity-90',
  outline:
    color === 'accent'
      ? 'lotus-border-muted border text-[var(--lotus-accent)] hover:border-[var(--lotus-accent)] hover:bg-[var(--lotus-accent-soft)]'
      : 'lotus-border-muted border text-[var(--lotus-text)] hover:bg-[var(--lotus-surface)]',
  soft:
    color === 'accent'
      ? 'bg-[var(--lotus-accent-soft)] text-[var(--lotus-accent)] hover:opacity-90'
      : 'bg-[var(--lotus-surface)] text-[var(--lotus-text)] hover:bg-[var(--lotus-accent-soft)]',
  ghost:
    color === 'accent'
      ? 'text-[var(--lotus-accent)] hover:bg-[var(--lotus-accent-soft)]'
      : 'text-[var(--lotus-text)] hover:bg-[var(--lotus-surface)]',
}[variant];
---

{
  href ? (
    <a
      class:list={[baseClasses, variantClasses, className]}
      href={href}
      rel={external ? 'noreferrer' : undefined}
      target={external ? '_blank' : undefined}
    >
      <slot />
      {trailingIconName && <Icon aria-hidden="true" class="h-4 w-4" name={trailingIconName} />}
    </a>
  ) : (
    <button class:list={[baseClasses, variantClasses, className]} type={type}>
      <slot />
      {trailingIconName && <Icon aria-hidden="true" class="h-4 w-4" name={trailingIconName} />}
    </button>
  )
}
