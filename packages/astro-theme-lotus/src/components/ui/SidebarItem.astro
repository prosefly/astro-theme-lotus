---
import { Badge, Icon } from '@prosefly/astro-components';
import { resolveIconName } from '../../lib/icons';
import type { DocsSidebarItem } from '../../lib/docs';
import type { SidebarBadge } from '../../lib/theme';

interface Props {
  item: DocsSidebarItem;
  currentPath?: string;
  depth?: number;
}

const { item, currentPath, depth = 0 } = Astro.props;
const hasChildren = Boolean(item.items?.length);

function normalizeHref(href: string): string {
  return href.endsWith('/') ? href : `${href}/`;
}

function isItemActive(link: DocsSidebarItem): boolean {
  if (!currentPath || !link.href) {
    return false;
  }

  return normalizeHref(link.href) === normalizeHref(currentPath);
}

function hasActiveChild(link: DocsSidebarItem): boolean {
  return Boolean(link.items?.some((child) => isItemActive(child) || hasActiveChild(child)));
}

function normalizeSidebarBadge(badge: SidebarBadge | undefined): Exclude<SidebarBadge, string> | undefined {
  if (!badge) {
    return undefined;
  }

  if (typeof badge === 'string') {
    return { label: badge };
  }

  return badge;
}

const active = isItemActive(item);
const expanded = active || hasActiveChild(item) || item.collapsed === false;
const iconName = item.icon ? resolveIconName(item.icon) : undefined;
const childItems = item.items ?? [];
const badge = normalizeSidebarBadge(item.badge);
const leadingBadge = badge?.position === 'leading' ? badge : undefined;
const trailingBadge = badge && badge.position !== 'leading' ? badge : undefined;
const linkClass = [
  'lotus-focus-ring flex min-h-9 w-full items-center gap-3 rounded-(--lotus-radius-md) px-3 py-1 text-sm transition-colors',
  depth > 0 && 'ps-6',
  active
    ? 'bg-(--lotus-accent-soft) font-medium text-(--lotus-accent)'
    : 'text-(--lotus-text-muted) hover:bg-(--lotus-surface) hover:text-(--lotus-text-strong)',
];
---

{
  hasChildren ? (
    <details class="group/sidebar-item" open={expanded}>
      <summary class:list={[linkClass, 'cursor-pointer marker:hidden']}>
        {leadingBadge && (
          <Badge
            class="lotus-sidebar-badge shrink-0"
            color={leadingBadge.color ?? 'neutral'}
            variant={leadingBadge.variant ?? 'soft'}
          >
            {leadingBadge.label}
          </Badge>
        )}
        {iconName && <Icon class="h-4 w-4 shrink-0 opacity-70" name={iconName} />}
        <span class="min-w-0 flex-1 truncate">{item.label}</span>
        {trailingBadge && (
          <Badge
            class="lotus-sidebar-badge shrink-0"
            color={trailingBadge.color ?? 'neutral'}
            variant={trailingBadge.variant ?? 'soft'}
          >
            {trailingBadge.label}
          </Badge>
        )}
        <Icon
          aria-hidden="true"
          class="h-4 w-4 shrink-0 text-(--lotus-text-muted) transition-transform group-open/sidebar-item:rotate-90"
          name="lucide:chevron-right"
        />
      </summary>
      <div class="mt-1">
        {childItems.map((child) => (
          <Astro.self item={child} currentPath={currentPath} depth={depth + 1} />
        ))}
      </div>
    </details>
  ) : (
    <a
      aria-current={active ? 'page' : undefined}
      class:list={linkClass}
      href={item.href ?? '#'}
      rel={item.external ? 'noreferrer' : undefined}
      target={item.external ? '_blank' : undefined}
    >
      {leadingBadge && (
        <Badge
          class="lotus-sidebar-badge shrink-0"
          color={leadingBadge.color ?? 'neutral'}
          variant={leadingBadge.variant ?? 'soft'}
        >
          {leadingBadge.label}
        </Badge>
      )}
      {iconName && <Icon class="h-4 w-4 shrink-0 opacity-70" name={iconName} />}
      <span class="min-w-0 flex-1 truncate">{item.label}</span>
      {trailingBadge && (
        <Badge
          class="lotus-sidebar-badge shrink-0"
          color={trailingBadge.color ?? 'neutral'}
          variant={trailingBadge.variant ?? 'soft'}
        >
          {trailingBadge.label}
        </Badge>
      )}
    </a>
  )
}

<style>
  :global(.lotus-sidebar-badge.pl-badge) {
    font-size: 0.625rem;
    letter-spacing: 0;
    padding: 0.1875rem 0.375rem;
  }
</style>
