---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/layout/Footer.astro';
import MainHeader from '../components/layout/MainHeader.astro';
import type { HeadConfig } from '../lib/page/head';
import type { NormalizedLocale } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  head?: HeadConfig;
  locale?: NormalizedLocale;
  pagefind?: boolean;
}

const { title, description, head, locale, pagefind = true } = Astro.props;
const pagefindAttrs = pagefind ? { 'data-pagefind-body': true } : { 'data-pagefind-ignore': true };
---

<BaseLayout title={title} description={description} head={head} locale={locale}>
  <MainHeader surface />

  <main class="mx-auto max-w-screen-2xl px-5 py-12 sm:px-6 sm:py-16">
    <article class="mx-auto max-w-3xl" {...pagefindAttrs}>
      <header class="mb-8 border-b border-(--lotus-border-subtle) pb-8">
        <h1 class="text-4xl font-semibold leading-tight tracking-normal text-(--lotus-text-strong)">
          {title}
        </h1>
        {description && (
          <p class="mt-4 text-base leading-7 text-(--lotus-text-muted)">
            {description}
          </p>
        )}
      </header>

      <div class="lotus-prose">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
