---
import '../styles/app.css';
import { Font } from 'astro:assets';
import { getThemeAttributes } from '../lib/appearance';
import { getFontCssVariables } from '../lib/fonts';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import type { LotusThemeConfig } from '../lib/theme';

interface Props {
  title?: string;
  description?: string;
}

const themeConfig = rawThemeConfig as LotusThemeConfig;
const { title, description = themeConfig.site.description } = Astro.props;
const themeAttrs = getThemeAttributes();
const pageTitle = title
  ? `${title} - ${themeConfig.site.title}`
  : themeConfig.site.title;
const fontCssVariables = getFontCssVariables(themeConfig);
const themeInitScript = `
(() => {
  try {
    const savedTheme = window.localStorage.getItem('lotus-theme');
    if (savedTheme === 'light' || savedTheme === 'dark') {
      document.documentElement.dataset.theme = savedTheme;
    }
  } catch {}
})();
`;
---

<html lang="en" {...themeAttrs}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={themeInitScript}></script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {fontCssVariables.map((cssVariable) => <Font cssVariable={cssVariable} />)}
  </head>
  <body class="min-h-screen bg-(--lotus-background) text-(--lotus-text)">
    <slot />
  </body>
</html>
