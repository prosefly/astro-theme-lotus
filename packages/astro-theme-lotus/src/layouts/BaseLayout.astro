---
import '../styles/app.css';
import { getThemeAttributes } from '../lib/appearance';
import rawThemeConfig from 'virtual:prosefly/lotus/config';
import type { LotusThemeConfig } from '../lib/theme';

interface Props {
  title?: string;
  description?: string;
}

const themeConfig = rawThemeConfig as LotusThemeConfig;
const { title, description = themeConfig.site.description } = Astro.props;
const themeAttrs = getThemeAttributes();
const pageTitle = title
  ? `${title} - ${themeConfig.site.title}`
  : themeConfig.site.title;
---

<html lang="en" {...themeAttrs}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-(--lotus-background) text-(--lotus-text)">
    <slot />
  </body>
</html>
