---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<li class="pl-step">
  <span class="pl-step__marker" aria-hidden="true" />
  <div class="pl-step__body">
    <h3 class="pl-step__title">{title}</h3>
    <div class="pl-step__content">
      <slot />
    </div>
  </div>
</li>

<style>
  .pl-step {
    position: relative;
    list-style: none;
  }

  .pl-step__marker {
    position: absolute;
    top: 0.375rem;
    left: -2.05rem;
    width: 0.75rem;
    height: 0.75rem;
    border: 2px solid var(--pl-background, #ffffff);
    border-radius: var(--pl-radius-full, 999px);
    background: var(--pl-accent, #4f46e5);
  }

  .pl-step__body {
    display: grid;
    gap: 0.75rem;
  }

  .pl-step__title {
    margin: 0;
    color: var(--pl-text-strong, var(--pl-text, #182230));
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.75rem;
  }

  .pl-step__content {
    color: var(--pl-text-muted, #667085);
    font-size: 1rem;
    line-height: 1.75rem;
  }

  .pl-step__content :global(> * + *) {
    margin-top: 0.75rem;
  }
</style>
