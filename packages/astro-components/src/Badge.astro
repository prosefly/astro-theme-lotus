---
interface Props {
  variant?: 'neutral' | 'accent' | 'success' | 'warning';
}

const { variant = 'neutral' } = Astro.props;
---

<span class="pl-badge" data-variant={variant}>
  <slot />
</span>

<style>
  .pl-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in oklab, var(--pl-surface, #f4f6f8) 82%, var(--pl-text-muted, #667085));
    border-radius: var(--pl-radius-full, var(--pl-radius-md, 999px));
    background: var(--pl-surface, #f4f6f8);
    color: var(--pl-text, #182230);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.25rem 0.625rem;
  }

  .pl-badge[data-variant='accent'] {
    border-color: color-mix(in oklab, var(--pl-accent, #4f46e5) 28%, var(--pl-surface, #f4f6f8));
    background: var(
      --pl-accent-soft,
      color-mix(in oklab, var(--pl-accent, #4f46e5) 12%, var(--pl-background, #ffffff))
    );
    color: var(--pl-accent, #4f46e5);
  }

  .pl-badge[data-variant='success'] {
    border-color: color-mix(in oklab, oklch(0.64 0.16 155) 28%, var(--pl-surface, #f4f6f8));
    background: color-mix(in oklab, oklch(0.64 0.16 155) 10%, var(--pl-background, #ffffff));
    color: oklch(0.45 0.13 155);
  }

  .pl-badge[data-variant='warning'] {
    border-color: color-mix(in oklab, oklch(0.74 0.16 80) 32%, var(--pl-surface, #f4f6f8));
    background: color-mix(in oklab, oklch(0.74 0.16 80) 12%, var(--pl-background, #ffffff));
    color: oklch(0.5 0.12 80);
  }
</style>
