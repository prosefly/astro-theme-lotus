---
interface Props {
  defaultValue?: string;
}

const { defaultValue } = Astro.props;
---

<section class="pl-tabs" data-default-value={defaultValue}>
  <div class="pl-tabs__header">
    <div>
      <p class="pl-tabs__title">Variant panels</p>
      <p class="pl-tabs__description">
        First release tabs render all panels in sequence for static documentation.
      </p>
    </div>
  </div>
  <div class="pl-tabs__panels">
    <slot />
  </div>
</section>

<style>
  .pl-tabs {
    margin-block: 2rem;
    border: 1px solid color-mix(in oklab, var(--pl-surface, #f4f6f8) 72%, var(--pl-text-muted, #667085));
    border-radius: var(--pl-radius-lg, 0.75rem);
    background: var(--pl-surface, #f4f6f8);
    padding: 1rem;
  }

  @media (min-width: 40rem) {
    .pl-tabs {
      padding: 1.25rem;
    }
  }

  .pl-tabs__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid color-mix(in oklab, var(--pl-surface, #f4f6f8) 72%, var(--pl-text-muted, #667085));
    padding-bottom: 0.75rem;
  }

  .pl-tabs__title {
    margin: 0;
    color: var(--pl-text, #182230);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.25rem;
  }

  .pl-tabs__description {
    margin: 0;
    color: var(--pl-text-muted, #667085);
    font-size: 0.875rem;
    line-height: 1.5rem;
  }

  .pl-tabs__panels {
    display: grid;
    gap: 1rem;
  }
</style>
