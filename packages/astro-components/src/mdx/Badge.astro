---
type BadgeVariant = 'solid' | 'soft' | 'subtle' | 'outline';
type BadgeColor = 'neutral' | 'accent' | 'success' | 'warning' | 'danger';

interface Props {
  variant?: BadgeVariant;
  color?: BadgeColor;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'soft',
  color = 'neutral',
  class: className,
  ...attrs
} = Astro.props;
---

<span
  class:list={['pl-badge', className]}
  data-color={color}
  data-variant={variant}
  {...attrs}
>
  <slot />
</span>

<style>
  .pl-badge {
    --pl-badge-color: var(--pl-text-strong, var(--pl-text, #182230));
    --pl-badge-solid: var(--pl-text-strong, var(--pl-text, #182230));
    --pl-badge-soft: var(--pl-surface, #f4f6f8);
    --pl-badge-contrast: var(--pl-background, #ffffff);
    --pl-badge-border: color-mix(
      in oklab,
      var(--pl-text-muted, #667085) 24%,
      transparent
    );

    align-items: center;
    border: 1px solid transparent;
    border-radius: var(--pl-radius-full, var(--pl-radius-md, 999px));
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 600;
    gap: 0.25rem;
    line-height: 1;
    padding: 0.25rem 0.625rem;
    vertical-align: baseline;
    white-space: nowrap;
  }

  .pl-badge[data-color='accent'] {
    --pl-badge-color: var(--pl-accent, #4f46e5);
    --pl-badge-solid: var(--pl-accent, #4f46e5);
    --pl-badge-soft: var(
      --pl-accent-soft,
      color-mix(in oklab, var(--pl-accent, #4f46e5) 12%, var(--pl-background, #ffffff))
    );
    --pl-badge-contrast: var(--pl-accent-contrast, #ffffff);
    --pl-badge-border: color-mix(
      in oklab,
      var(--pl-accent, #4f46e5) 28%,
      transparent
    );
  }

  .pl-badge[data-color='success'] {
    --pl-badge-color: oklch(0.45 0.13 155);
    --pl-badge-solid: oklch(0.55 0.14 155);
    --pl-badge-soft: color-mix(
      in oklab,
      oklch(0.64 0.16 155) 12%,
      var(--pl-background, #ffffff)
    );
    --pl-badge-contrast: #ffffff;
    --pl-badge-border: color-mix(
      in oklab,
      oklch(0.64 0.16 155) 30%,
      transparent
    );
  }

  .pl-badge[data-color='warning'] {
    --pl-badge-color: oklch(0.5 0.12 80);
    --pl-badge-solid: oklch(0.76 0.16 80);
    --pl-badge-soft: color-mix(
      in oklab,
      oklch(0.74 0.16 80) 14%,
      var(--pl-background, #ffffff)
    );
    --pl-badge-contrast: oklch(0.18 0.04 80);
    --pl-badge-border: color-mix(
      in oklab,
      oklch(0.74 0.16 80) 34%,
      transparent
    );
  }

  .pl-badge[data-color='danger'] {
    --pl-badge-color: oklch(0.52 0.18 25);
    --pl-badge-solid: oklch(0.58 0.2 25);
    --pl-badge-soft: color-mix(
      in oklab,
      oklch(0.62 0.2 25) 12%,
      var(--pl-background, #ffffff)
    );
    --pl-badge-contrast: #ffffff;
    --pl-badge-border: color-mix(
      in oklab,
      oklch(0.62 0.2 25) 30%,
      transparent
    );
  }

  .pl-badge[data-variant='solid'] {
    background: var(--pl-badge-solid);
    border-color: var(--pl-badge-solid);
    color: var(--pl-badge-contrast);
  }

  .pl-badge[data-variant='soft'] {
    background: var(--pl-badge-soft);
    color: var(--pl-badge-color);
  }

  .pl-badge[data-variant='subtle'] {
    background: var(--pl-badge-soft);
    border-color: var(--pl-badge-border);
    color: var(--pl-badge-color);
  }

  .pl-badge[data-variant='outline'] {
    background: transparent;
    border-color: var(--pl-badge-border);
    color: var(--pl-badge-color);
  }

</style>
