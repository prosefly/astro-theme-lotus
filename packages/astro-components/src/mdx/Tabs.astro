---
import Icon from './Icon.astro';
import { processPanels } from './rehype-tabs';

interface Props {
  copy?: boolean | string;
  defaultValue?: string;
  syncKey?: string;
}

const { copy, defaultValue, syncKey } = Astro.props;
const hasCopy = copy === true || copy === 'true' || copy === '';
const tabsId = `pl-tabs-${globalThis.crypto.randomUUID()}`;
const panelHtml = await Astro.slots.render('default');
const { activeIndex, html, panels } = processPanels(panelHtml, {
  defaultValue,
  idPrefix: tabsId,
});
const hasIcons = panels.some((panel) => panel.icon);
const activePanel = panels[activeIndex] ?? panels[0];
---

<section class="pl-tabs" data-pl-tabs data-sync-key={syncKey}>
  <div class="pl-tabs__header">
    {
      hasIcons && (
        <div
          aria-hidden="true"
          class="pl-tabs__active-icons"
          hidden={!activePanel?.icon}
        >
          {panels.map((panel, index) => (
            panel.icon && (
              <span
                class="pl-tabs__active-icon"
                data-pl-tabs-icon-for={panel.panelId}
                hidden={index !== activeIndex}
              >
                <Icon name={panel.icon} />
              </span>
            )
          ))}
        </div>
      )
    }
    <div aria-label="Tabs" class="pl-tabs__list" role="tablist">
      {
        panels.map((panel, index) => (
          <button
            aria-controls={panel.panelId}
            aria-selected={index === activeIndex ? 'true' : 'false'}
            class="pl-tabs__trigger"
            data-pl-tabs-trigger
            data-tab-label={panel.label}
            data-tab-panel={panel.panelId}
            data-tab-value={panel.value}
            id={panel.tabId}
            role="tab"
            tabindex={index === activeIndex ? '0' : '-1'}
            type="button"
          >
            {panel.label}
          </button>
        ))
      }
    </div>
    {
      hasCopy && (
        <button
          aria-label="Copy code"
          class="pl-tabs__copy"
          data-pl-tabs-copy
          title="Copy code"
          type="button"
        >
          <span class="pl-tabs__copy-icon" data-pl-tabs-copy-icon="copy">
            <Icon name="lucide:copy" />
          </span>
          <span class="pl-tabs__copy-icon" data-pl-tabs-copy-icon="check" hidden>
            <Icon name="lucide:check" />
          </span>
        </button>
      )
    }
  </div>
  <div class="pl-tabs__panels" set:html={html} />
</section>

<script is:inline>
  (() => {
    const initKey = '__proseflyTabsInit';

    if (!window[initKey]) {
      const getStoredLabel = (syncKey) => {
        if (!syncKey) return undefined;
        try {
          return localStorage.getItem(`pl-tabs:${syncKey}`) ?? undefined;
        } catch {
          return undefined;
        }
      };

      const storeLabel = (syncKey, label) => {
        if (!syncKey || !label) return;
        try {
          localStorage.setItem(`pl-tabs:${syncKey}`, label);
        } catch {
          // Ignore storage failures in restricted browsing contexts.
        }
      };

      const writeClipboard = async (text) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        throw new Error('Clipboard API is not available.');
      };

      const setCopyState = (button, copied) => {
        const copyIcon = button.querySelector('[data-pl-tabs-copy-icon="copy"]');
        const checkIcon = button.querySelector('[data-pl-tabs-copy-icon="check"]');

        copyIcon?.toggleAttribute('hidden', copied);
        checkIcon?.toggleAttribute('hidden', !copied);
        button.setAttribute('aria-label', copied ? 'Copied' : 'Copy code');
        button.setAttribute('title', copied ? 'Copied' : 'Copy code');
      };

      const getActiveCode = (root) => {
        const activePanel = root.querySelector('.pl-tabs__panel:not([hidden])');
        const code = activePanel?.querySelector('pre code');

        return code?.textContent ?? '';
      };

      const setActiveIcon = (root, panelId) => {
        const iconContainer = root.querySelector('.pl-tabs__active-icons');
        const icons = [...root.querySelectorAll('[data-pl-tabs-icon-for]')];

        if (!(iconContainer instanceof HTMLElement)) return;

        let hasActiveIcon = false;
        icons.forEach((icon) => {
          const isActive = icon.getAttribute('data-pl-tabs-icon-for') === panelId;
          icon.toggleAttribute('hidden', !isActive);
          hasActiveIcon ||= isActive;
        });
        iconContainer.toggleAttribute('hidden', !hasActiveIcon);
      };

      const activate = (root, trigger, options = {}) => {
        const panelId = trigger.getAttribute('data-tab-panel');
        const label = trigger.getAttribute('data-tab-label');
        const syncKey = root.getAttribute('data-sync-key');
        const triggers = [...root.querySelectorAll('[data-pl-tabs-trigger]')];
        const panels = [...root.querySelectorAll('.pl-tabs__panel')];

        triggers.forEach((button) => {
          const isActive = button === trigger;
          button.setAttribute('aria-selected', isActive ? 'true' : 'false');
          button.setAttribute('tabindex', isActive ? '0' : '-1');
        });

        panels.forEach((panel) => {
          panel.toggleAttribute('hidden', panel.id !== panelId);
        });

        setActiveIcon(root, panelId);

        if (options.focus) {
          trigger.focus();
        }

        if (options.persist === false) {
          return;
        }

        storeLabel(syncKey, label);

        if (!syncKey || !label) {
          return;
        }

        document.querySelectorAll('[data-pl-tabs]').forEach((otherRoot) => {
          if (otherRoot === root || otherRoot.getAttribute('data-sync-key') !== syncKey) {
            return;
          }

          const matchingTrigger = [
            ...otherRoot.querySelectorAll('[data-pl-tabs-trigger]'),
          ].find((button) => button.getAttribute('data-tab-label') === label);

          if (matchingTrigger) {
            activate(otherRoot, matchingTrigger, { persist: false });
          }
        });
      };

      window[initKey] = () => {
        document.querySelectorAll('[data-pl-tabs]').forEach((root) => {
          if (root instanceof HTMLElement && root.dataset.plTabsReady === 'true') {
            return;
          }

          const triggers = [...root.querySelectorAll('[data-pl-tabs-trigger]')];
          const syncKey = root.getAttribute('data-sync-key');
          const storedLabel = getStoredLabel(syncKey);
          const storedTrigger = storedLabel
            ? triggers.find((button) => button.getAttribute('data-tab-label') === storedLabel)
            : undefined;
          const selectedTrigger =
            storedTrigger ??
            triggers.find((button) => button.getAttribute('aria-selected') === 'true') ??
            triggers[0];

          if (root instanceof HTMLElement) {
            root.dataset.plTabsReady = 'true';
          }

          if (selectedTrigger) {
            activate(root, selectedTrigger, { persist: false });
          }

          triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => activate(root, trigger));
            trigger.addEventListener('keydown', (event) => {
              const currentIndex = triggers.indexOf(trigger);
              let nextIndex = currentIndex;

              if (event.key === 'ArrowRight') nextIndex = currentIndex + 1;
              else if (event.key === 'ArrowLeft') nextIndex = currentIndex - 1;
              else if (event.key === 'Home') nextIndex = 0;
              else if (event.key === 'End') nextIndex = triggers.length - 1;
              else return;

              event.preventDefault();
              const nextTrigger =
                triggers[(nextIndex + triggers.length) % triggers.length];
              activate(root, nextTrigger, { focus: true });
            });
          });

          root.querySelectorAll('[data-pl-tabs-copy]').forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) {
              return;
            }

            button.addEventListener('click', async () => {
              const text = getActiveCode(root);

              if (!text) {
                return;
              }

              try {
                await writeClipboard(text);
                setCopyState(button, true);
                window.setTimeout(() => setCopyState(button, false), 1600);
              } catch {
                setCopyState(button, false);
              }
            });
          });
        });
      };

      document.addEventListener('astro:page-load', window[initKey]);
    }

    window[initKey]();
  })();
</script>

<style is:global>
  .pl-tabs {
    background: var(--pl-surface, #f4f6f8);
    border-radius: var(--pl-radius-lg, 0.75rem);
    margin-block: 1.25rem;
    overflow: hidden;
  }

  .pl-tabs__header {
    align-items: center;
    background: var(--pl-surface, #f4f6f8);
    border-bottom: 1px solid var(--pl-border-subtle, #e5e7eb);
    display: flex;
    gap: 0.625rem;
    padding: 0.5rem 1rem;
  }

  .pl-tabs__active-icons {
    align-items: center;
    color: var(--pl-text, #344054);
    display: inline-grid;
    flex: 0 0 auto;
    justify-content: center;
  }

  .pl-tabs__active-icons[hidden],
  .pl-tabs__active-icon[hidden],
  .pl-tabs__copy-icon[hidden],
  .pl-tabs__panel[hidden] {
    display: none;
  }

  .pl-tabs__active-icon,
  .pl-tabs__active-icon > svg {
    height: 1rem;
    width: 1rem;
  }

  .pl-tabs__list {
    align-items: center;
    background: transparent;
    display: inline-flex;
    flex: 1 1 auto;
    gap: 0.25rem;
    max-width: 100%;
    min-width: 0;
    overflow-x: auto;
    padding: 0;
    scrollbar-width: none;
  }

  .pl-tabs__list::-webkit-scrollbar {
    display: none;
  }

  .pl-tabs__trigger {
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--pl-radius-md, 0.5rem);
    color: var(--pl-text-muted, #667085);
    cursor: pointer;
    flex: 0 0 auto;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25rem;
    padding: 0.25rem 0.5rem;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease,
      color 160ms ease;
  }

  .pl-tabs__trigger:hover {
    color: var(--pl-text-strong, var(--pl-text, #182230));
  }

  .pl-tabs__trigger:focus-visible {
    outline: 2px solid var(--pl-accent, #4f46e5);
    outline-offset: 2px;
  }

  .pl-tabs__trigger[aria-selected='true'] {
    background: var(--pl-background, #ffffff);
    border-color: var(--pl-border-muted, #d0d5dd);
    box-shadow: none;
    color: var(--pl-text-strong, var(--pl-text, #182230));
  }

  .pl-tabs__copy {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--pl-radius-md, 0.5rem);
    color: var(--pl-text-muted, #667085);
    cursor: pointer;
    display: inline-flex;
    flex: 0 0 auto;
    height: 1.875rem;
    justify-content: center;
    margin-inline-start: auto;
    padding: 0;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
    width: 1.875rem;
  }

  .pl-tabs__copy:hover {
    background: var(--pl-background, #ffffff);
    border-color: var(--pl-border-muted, #d0d5dd);
    color: var(--pl-text-strong, var(--pl-text, #182230));
  }

  .pl-tabs__copy:focus-visible {
    outline: 2px solid var(--pl-accent, #4f46e5);
    outline-offset: 2px;
  }

  .pl-tabs__copy-icon,
  .pl-tabs__copy-icon > svg {
    height: 1rem;
    width: 1rem;
  }

  .pl-tabs__panels {
    background: var(--pl-surface, #f4f6f8);
    padding: 1rem;
  }

  .pl-tabs__panel {
    color: var(--pl-text, #344054);
  }

  .pl-tabs__panel:focus-visible {
    border-radius: var(--pl-radius-md, 0.5rem);
    outline: 2px solid var(--pl-accent, #4f46e5);
    outline-offset: 2px;
  }

  .pl-tabs__panel > :first-child {
    margin-block-start: 0;
  }

  .pl-tabs__panel > :last-child {
    margin-block-end: 0;
  }

  .pl-tabs__panel pre {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 0;
  }
</style>
